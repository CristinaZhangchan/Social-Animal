# Environment Variables for Supabase Authentication

# Get these values from your Supabase project dashboard:
# 1. Go to https://supabase.com/dashboard
# 2. Select your project or create a new one
# 3. Go to Settings > API
# 4. Copy the URL and anon/public key

NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# LiveAvatar runtime config
LIVEAVATAR_API_KEY=your_liveavatar_api_key
LIVEAVATAR_SANDBOX_AVATAR_ID=dd73ea75-1218-4ef3-92ce-606d5f7fbc0a
LIVEAVATAR_SANDBOX_MODE=false

# Example:
# NEXT_PUBLIC_SUPABASE_URL=https://abc123.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
