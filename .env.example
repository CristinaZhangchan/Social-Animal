# CharmUp Web Demo - Environment Variables Template
# Copy this file to .env.local and fill in your API keys

# OpenAI API (for Whisper STT and GPT-4o)
# OpenAI API (for Whisper STT and GPT-4o)
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# ElevenLabs API (for Text-to-Speech)
ELEVENLABS_API_KEY=YOUR_ELEVENLABS_API_KEY

# HeyGen API (for Video Avatar - Legacy)
HEYGEN_API_KEY=YOUR_HEYGEN_API_KEY

# LiveAvatar API (Get from: https://app.liveavatar.com/developers)
LIVEAVATAR_API_KEY=YOUR_LIVEAVATAR_API_KEY
# Sandbox avatar ID (Wayne) - only used when LIVEAVATAR_SANDBOX_MODE=true
LIVEAVATAR_SANDBOX_AVATAR_ID=dd73ea75-1218-4ef3-92ce-606d5f7fbc0a
# Product mode should stay false. Turn on only when you explicitly want sandbox behavior.
LIVEAVATAR_SANDBOX_MODE=false

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Analytics
# NEXT_PUBLIC_ANALYTICS_ID=...
